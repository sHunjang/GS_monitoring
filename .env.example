# ==============================================
# 센서 모니터링 시스템 환경 변수 설정
# ==============================================
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 수정하세요
# 복사 명령: copy .env.example .env (Windows) 또는 cp .env.example .env (Linux/Mac)

# ----------------------------------------------
# 데이터베이스 설정 (PostgreSQL)
# ----------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sensor_goseong                   # 고성 센서 모니터링
DB_USER=postgres
DB_PASSWORD=your_password_here

# ----------------------------------------------
# 전력량 센서 설정
# ----------------------------------------------
# 통신 방식: serial (유선) 또는 tcp (무선)
ENERGY_CONNECTION_TYPE=serial

# 유선 연결 설정 (RS-485)
ENERGY_SERIAL_PORT=COM3                  # Windows: COM3, Linux: /dev/ttyUSB0
ENERGY_SERIAL_BAUDRATE=9600
ENERGY_SERIAL_TIMEOUT=1

# 무선 연결 설정 (Modbus TCP)
ENERGY_TCP_HOST=192.168.1.100            # 센서 IP 주소
ENERGY_TCP_PORT=502                      # Modbus TCP 포트 (기본 502)

# Modbus 설정
# 주의: 유선(serial)일 때 - SLAVE_ID를 10, 11, 12... 로 설정 (센서별로 다름)
#      무선(tcp)일 때 - SLAVE_ID는 1로 고정, IP만 다르게 설정
ENERGY_SLAVE_ID=10                       # 유선: 10, 11, 12... / 무선: 1
ENERGY_REGISTER_START=0                  # 시작 레지스터 주소 (센서 매뉴얼 확인)
ENERGY_REGISTER_COUNT=2                  # 읽을 레지스터 개수

# ----------------------------------------------
# 온습도 센서 설정
# ----------------------------------------------
ENV_CONNECTION_TYPE=serial

# 유선 연결
ENV_SERIAL_PORT=COM3                     # 전력량과 같은 포트 사용 가능 (RS-485 버스 공유)
ENV_SERIAL_BAUDRATE=9600
ENV_SERIAL_TIMEOUT=1

# 무선 연결
ENV_TCP_HOST=192.168.1.101               # 온습도 센서 IP (전력량과 다른 IP)
ENV_TCP_PORT=502

# Modbus 설정
# 유선: 20, 21, 22... / 무선: 1
ENV_SLAVE_ID=20
ENV_REGISTER_START=0
ENV_REGISTER_COUNT=2                     # 온도 1개 + 습도 1개

# ----------------------------------------------
# 일사량 센서 설정
# ----------------------------------------------
SOLAR_CONNECTION_TYPE=tcp                # 예: 무선 사용

# 유선 연결
SOLAR_SERIAL_PORT=COM3
SOLAR_SERIAL_BAUDRATE=9600
SOLAR_SERIAL_TIMEOUT=1

# 무선 연결
SOLAR_TCP_HOST=192.168.1.102             # 일사량 센서 IP
SOLAR_TCP_PORT=502

# Modbus 설정
# 유선: 30, 31, 32... / 무선: 1
SOLAR_SLAVE_ID=1                         # 무선이므로 1 (IP로 구분됨)
SOLAR_REGISTER_START=0
SOLAR_REGISTER_COUNT=1

# ----------------------------------------------
# 데이터 수집 설정
# ----------------------------------------------
COLLECTION_INTERVAL=60                   # 데이터 수집 주기 (초) - 1분마다

# 데이터 보관 기간 (현재 미사용)
# DATA_RETENTION_DAYS=30

# ----------------------------------------------
# 로깅 설정
# ----------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760                   # 10MB
LOG_BACKUP_COUNT=5

# ----------------------------------------------
# 애플리케이션 설정
# ----------------------------------------------
APP_NAME=고성 센서 모니터링 시스템
APP_VERSION=1.0.0


# ==============================================
# 설정 예시
# ==============================================

# 예시 1: 모든 센서를 유선(RS-485)으로 연결
# -----------------------------------------------
# ENERGY_CONNECTION_TYPE=serial
# ENERGY_SERIAL_PORT=COM3
# ENERGY_SLAVE_ID=10                    # 전력량 센서 #1
# 
# ENV_CONNECTION_TYPE=serial
# ENV_SERIAL_PORT=COM3                  # 같은 포트 공유
# ENV_SLAVE_ID=20                       # 온습도 센서 #1
# 
# SOLAR_CONNECTION_TYPE=serial
# SOLAR_SERIAL_PORT=COM3                # 같은 포트 공유
# SOLAR_SLAVE_ID=30                     # 일사량 센서 #1

# 예시 2: 모든 센서를 무선(Modbus TCP)으로 연결
# -----------------------------------------------
# ENERGY_CONNECTION_TYPE=tcp
# ENERGY_TCP_HOST=192.168.1.100
# ENERGY_SLAVE_ID=1                     # 무선은 모두 1
# 
# ENV_CONNECTION_TYPE=tcp
# ENV_TCP_HOST=192.168.1.101            # 다른 IP
# ENV_SLAVE_ID=1
# 
# SOLAR_CONNECTION_TYPE=tcp
# SOLAR_TCP_HOST=192.168.1.102          # 다른 IP
# SOLAR_SLAVE_ID=1

# 예시 3: 혼합 (전력량 유선, 온습도/일사량 무선)
# -----------------------------------------------
# ENERGY_CONNECTION_TYPE=serial
# ENERGY_SERIAL_PORT=COM3
# ENERGY_SLAVE_ID=10
# 
# ENV_CONNECTION_TYPE=tcp
# ENV_TCP_HOST=192.168.1.101
# ENV_SLAVE_ID=1
# 
# SOLAR_CONNECTION_TYPE=tcp
# SOLAR_TCP_HOST=192.168.1.102
# SOLAR_SLAVE_ID=1

# 예시 4: 여러 전력량 센서 (유선)
# -----------------------------------------------
# 센서 1:
# ENERGY_SLAVE_ID=10
# 
# 센서 2 (다른 장치):
# ENERGY_SLAVE_ID=11
# 
# 센서 3:
# ENERGY_SLAVE_ID=12
# 
# 주의: 프로그램에서 여러 센서를 읽으려면
#      코드에서 각 SLAVE_ID별로 읽기 필요
