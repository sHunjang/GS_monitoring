# ==============================================
# 센서 모니터링 시스템 설정 파일
# ==============================================
# 이 파일을 exe와 같은 폴더에 배치하세요!
# 
# 주의사항:
# 1. 각 PC마다 설정이 다를 수 있으므로 확인 필요
# 2. COM 포트 번호는 장치 관리자에서 확인
# 3. DB 주소는 PostgreSQL 서버 위치에 맞게 설정

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 데이터베이스 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PostgreSQL 서버 주소 (localhost 또는 IP)
DB_HOST=localhost

# PostgreSQL 포트 (기본값: 5432)
DB_PORT=5432

# 데이터베이스 이름
DB_NAME=sensor_goseong

# 데이터베이스 사용자 이름
DB_USER=postgres

# 데이터베이스 비밀번호
DB_PASSWORD=****


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 전력량 센서 설정 (Modbus RTU)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 시리얼 포트
# - Windows: COM7, COM11 등
# - Linux: /dev/ttyUSB0, /dev/ttyUSB1 등
ENERGY_SERIAL_PORT=COM11

# 통신 속도 (baud rate)
ENERGY_SERIAL_BAUDRATE=9600

# 타임아웃 (초)
ENERGY_SERIAL_TIMEOUT=3

# Slave ID 목록 (콤마로 구분)
# - 1~29: 단상 센서 (DDS238-2)
# - 30 이상: 3상 센서 (TAC4300)
# 예: 11,12,31,32 → Energy_1(11), Energy_2(12), Energy_3(31), Energy_4(32)
ENERGY_SLAVE_IDS=11,12,31,32


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 환경 센서 설정 (ASCII Protocol)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 시리얼 포트 (전력 센서와 같은 포트 사용 가능)
ENV_SERIAL_PORT=COM11

# 통신 속도
ENV_SERIAL_BAUDRATE=9600

# 타임아웃 (초)
ENV_SERIAL_TIMEOUT=1

# 센서 ID 목록 (콤마로 구분)
# - 0~9 사용 가능
# 예: 0,1 → Env_1(센서ID=0), Env_2(센서ID=1)
ENV_SENSOR_IDS=0,1


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 데이터 수집 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 수집 주기 (초)
# 예: 60 → 1분마다 수집
COLLECTION_INTERVAL=60


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 로깅 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE_PATH=logs/app.log

# 로그 파일 최대 크기 (바이트)
# 10485760 = 10MB
LOG_MAX_BYTES=10485760

# 로그 파일 백업 개수
LOG_BACKUP_COUNT=5


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 애플리케이션 정보
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_NAME=고성 센서 모니터링 시스템
APP_VERSION=1.0.0